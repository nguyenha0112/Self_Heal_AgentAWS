{
  "profile_name": "cdo-02-self-heal-tenant-a",
  "system": "K8S_NATIVE",
  "default_namespace": "tenant-a",
  "default_deployment_template": "deployment/cdo-sample-api",
  "default_service": "checkout-svc",
  "allowed_namespaces": [
    "tenant-a"
  ],
  "services": [
    "checkout-svc"
  ],
  "metric_types": [
    "oom_kill",
    "memory_pressure",
    "oom_persist",
    "bad_deploy",
    "scale_capacity",
    "crashloop",
    "latency",
    "service_stuck",
    "default"
  ],
  "fault_runbook_mapping": {
    "oom_kill": "OOMPatchMemoryRunbook",
    "memory_pressure": "OOMPatchMemoryRunbook",
    "oom_persist": "OOMPatchMemoryRunbook",
    "bad_deploy": "BadDeployRollbackRunbook",
    "scale_capacity": "CapacityScaleRunbook",
    "queue_backlog": "CapacityScaleRunbook",
    "crashloop": "ServiceStuckRestartRunbook",
    "latency": "ServiceStuckRestartRunbook",
    "service_stuck": "ServiceStuckRestartRunbook",
    "default": "ServiceStuckRestartRunbook"
  },
  "dependency_graph": {
    "checkout-svc": []
  },
  "runbooks": {
    "OOMPatchMemoryRunbook": {
      "name": "OOMPatchMemoryRunbook",
      "description": "Tenant-a OOM and memory pressure recovery for checkout-svc.",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "PATCH_MEMORY_LIMIT",
          "target": "deployment/cdo-sample-api",
          "params": {
            "namespace": "tenant-a",
            "container": "podinfo",
            "memory_request_mb": 128,
            "memory_limit_mb": 256
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true",
          "restart_count_no_increase == true"
        ]
      }
    },
    "BadDeployRollbackRunbook": {
      "name": "BadDeployRollbackRunbook",
      "description": "Tenant-a rollback for bad deploy on checkout-svc.",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "ROLLOUT_UNDO",
          "target": "deployment/cdo-sample-api",
          "params": {
            "namespace": "tenant-a"
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true",
          "service_error_rate < 0.01"
        ]
      }
    },
    "CapacityScaleRunbook": {
      "name": "CapacityScaleRunbook",
      "description": "Tenant-a deferred scale runbook for checkout-svc.",
      "pattern_type": "deferred",
      "action_plan": [
        {
          "step": 1,
          "action": "SCALE_REPLICAS",
          "target": "deployment/cdo-sample-api",
          "params": {
            "namespace": "tenant-a",
            "replicas": 4
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true"
        ]
      }
    },
    "ServiceStuckRestartRunbook": {
      "name": "ServiceStuckRestartRunbook",
      "description": "Tenant-a service restart runbook for checkout-svc.",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "RESTART_DEPLOYMENT",
          "target": "deployment/cdo-sample-api",
          "params": {
            "namespace": "tenant-a",
            "grace_period_seconds": 30
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true",
          "service_latency_p95 < 200.0"
        ]
      }
    }
  }
}
